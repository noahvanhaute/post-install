#!/usr/bin/env bash

RED='\e[31m'
GREEN='\e[32m'
DEFAULT='\e[39m'
HIDE_CURSOR='\e[?25l'
SHOW_CURSOR='\e[?25h'

ESSENTIAL_PACKAGES=(
